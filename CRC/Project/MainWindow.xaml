<Window x:Class="ModbusFrameTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Modbus RTU 原始帧生成器"
        Width="960"
        Height="640"
        MinWidth="900"
        MinHeight="600"
        Icon="Assets/CRC.ico"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F7FB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="24"
                CornerRadius="20"
                Background="#FF0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="14"
                               Foreground="#FF93C5FD"
                               FontWeight="SemiBold"
                               Text="G780S 透传 / USART3 / STM32 Modbus RTU" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="远程维护原始帧生成器" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="#FFCBD5E1"
                               Text="输入从站地址、功能码、寄存器和数据，软件会自动计算 CRC16、生成原始帧并复制到剪贴板。" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="16,10"
                        CornerRadius="14"
                        Background="#1E293B">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   Foreground="#94A3B8"
                                   Text="当前状态" />
                        <TextBlock x:Name="HeaderStatusText"
                                   Margin="0,4,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#F8FAFC"
                                   Text="等待输入" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="24"
                    CornerRadius="20"
                    Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               Text="输入参数" />

                    <UniformGrid Grid.Row="2"
                                 Columns="2"
                                 Rows="2">
                        <StackPanel Margin="0,0,12,16">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#334155"
                                       Text="从站地址" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="SlaveAddressBaseButton"
                                        Height="42"
                                        Click="BaseButton_OnClick"
                                        Tag="SlaveAddress"
                                        Background="#E2E8F0"
                                        Foreground="#334155"
                                        FontFamily="Consolas"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Content="0x" />
                                <TextBox x:Name="SlaveAddressTextBox"
                                         Grid.Column="1"
                                         Height="42"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         TextChanged="InputTextBox_OnTextChanged"
                                         ToolTip="1 字节，例如 0A" />
                            </Grid>
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#64748B"
                                           Text="1 字节，可切换 HEX / DEC 输入" />
                        </StackPanel>

                        <StackPanel Margin="12,0,0,16">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#334155"
                                       Text="功能码" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="FunctionCodeBaseButton"
                                        Height="42"
                                        Click="BaseButton_OnClick"
                                        Tag="FunctionCode"
                                        Background="#E2E8F0"
                                        Foreground="#334155"
                                        FontFamily="Consolas"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Content="0x" />
                                <TextBox x:Name="FunctionCodeTextBox"
                                         Grid.Column="1"
                                         Height="42"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         TextChanged="InputTextBox_OnTextChanged"
                                         ToolTip="1 字节，例如 06" />
                            </Grid>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       Text="1 字节，例如 03 / 06 / 10" />
                        </StackPanel>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#334155"
                                       Text="寄存器地址" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="RegisterAddressBaseButton"
                                        Height="42"
                                        Click="BaseButton_OnClick"
                                        Tag="RegisterAddress"
                                        Background="#E2E8F0"
                                        Foreground="#334155"
                                        FontFamily="Consolas"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Content="0x" />
                                <TextBox x:Name="RegisterAddressTextBox"
                                         Grid.Column="1"
                                         Height="42"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         TextChanged="InputTextBox_OnTextChanged"
                                         ToolTip="2 字节，例如 0030" />
                            </Grid>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       Text="2 字节，高字节在前" />
                        </StackPanel>

                        <StackPanel Margin="12,0,0,0">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#334155"
                                       Text="数据" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="DataBaseButton"
                                        Height="42"
                                        Click="BaseButton_OnClick"
                                        Tag="Data"
                                        Background="#E2E8F0"
                                        Foreground="#334155"
                                        FontFamily="Consolas"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Content="0x" />
                                <TextBox x:Name="DataTextBox"
                                         Grid.Column="1"
                                         Height="42"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         TextChanged="InputTextBox_OnTextChanged"
                                         ToolTip="2 字节，例如 A55A" />
                            </Grid>
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       Text="2 字节，按寄存器写入值" />
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal">
                        <Button x:Name="GenerateButton"
                                Width="160"
                                Height="44"
                                Click="GenerateButton_OnClick"
                                Background="#0F766E"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Content="生成并复制" />
                        <Button Width="120"
                                Height="44"
                                Margin="12,0,0,0"
                                Click="FillExampleButton_OnClick"
                                Background="#E2E8F0"
                                Foreground="#0F172A"
                                BorderThickness="0"
                                Content="填入示例" />
                        <TextBlock Margin="16,10,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   Text="示例：0A / 06 / 0030 / A55A" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="24"
                    CornerRadius="20"
                    Background="#FFF8FAFC">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               Text="生成结果" />

                    <Border Grid.Row="2"
                            Padding="16"
                            CornerRadius="16"
                            Background="#0F172A">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       Foreground="#93C5FD"
                                       Text="原始帧" />
                            <TextBox x:Name="RawFrameTextBox"
                                     Margin="0,8,0,0"
                                     Background="#0F172A"
                                     Foreground="White"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="22"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <UniformGrid Grid.Row="4"
                                 Columns="2">
                        <Border Margin="0,0,8,0"
                                Padding="14"
                                CornerRadius="14"
                                Background="White">
                            <StackPanel>
                                <TextBlock Foreground="#64748B"
                                           Text="CRC16" />
                                <TextBlock x:Name="CrcTextBlock"
                                           Margin="0,6,0,0"
                                           FontFamily="Consolas"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           Text="--" />
                            </StackPanel>
                        </Border>

                        <Border Margin="8,0,0,0"
                                Padding="14"
                                CornerRadius="14"
                                Background="White">
                            <StackPanel>
                                <TextBlock Foreground="#64748B"
                                           Text="复制状态" />
                                <TextBlock x:Name="CopyStatusTextBlock"
                                           Margin="0,6,0,0"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#0F766E"
                                           Text="等待生成" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="6"
                            Padding="16"
                            CornerRadius="16"
                            Background="White">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#0F172A"
                                       Text="下一步" />
                            <TextBlock x:Name="NextStepTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="#334155"
                                       TextWrapping="Wrap"
                                       Text="先输入完整参数，然后点击“生成并复制”。" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
