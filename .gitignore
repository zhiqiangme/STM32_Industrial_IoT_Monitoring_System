STM32/**/*.ewd
STM32/**/*.ewp~
STM32/**/*.dni
STM32/**/*.dbgdt
STM32/**/*.wsdt
STM32/**/*.wspos
STM32/**/EWARM/Debug/
STM32/**/EWARM/Release/
STM32/**/EWARM/settings/

