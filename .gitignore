####################################
# 通用忽略规则 (所有目录生效)
####################################

# --- 白名单目录 ---
!文档/
!文档/**

# --- OS 系统文件 ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- 临时文件 ---
*.swp
*.swo
*.tmp
*.temp
*~

# --- git和Vscode文件 ---
.git/
.vscode/

####################################
# STM32 目录 (Keil MDK / STM32CubeIDE / IAR)
####################################

# --- Keil MDK 编译输出 ---
STM32/**/*.o
STM32/**/*.d
STM32/**/*.crf
STM32/**/*.dep
STM32/**/*.axf
STM32/**/*.htm
STM32/**/*.lnp
STM32/**/*.sct
STM32/**/*.lst
