####################################
# Android 目录 (Gradle / Android Studio)
####################################

# --- IDE 配置 ---
Android/**/.idea/
Android/**/*.iml
Android/**/*.ipr
Android/**/*.iws
Android/**/.classpath
Android/**/.project
Android/**/.metadata/

# --- Gradle 缓存和构建输出 ---
Android/**/.gradle/
Android/**/build/
Android/**/.kotlin/
Android/**/out/
Android/**/bin/
Android/**/gen/
Android/**/dist/

# --- 本地配置 ---
Android/**/local.properties

# --- Android 构建产物 ---
Android/**/*.apk
Android/**/*.aab
Android/**/*.ap_
Android/**/*.dex
Android/**/*.class

# --- Native 构建中间文件 ---
Android/**/.externalNativeBuild/
Android/**/.cxx/
Android/**/captures/

# --- ProGuard ---
Android/**/proguard/

# --- Android Studio ---
Android/**/*.hprof
Android/**/.navigation/

####################################
# Harmony 目录 (DevEco / hvigor / ohpm)
####################################

# --- IDE 配置 ---
Harmony/**/.idea/
Harmony/**/*.iml

# --- hvigor 生成的缓存/输出 ---
Harmony/**/.hvigor/

# --- ohpm 依赖缓存 ---
Harmony/**/oh_modules/
Harmony/**/.ohpm/

# --- App Analyzer 输出/缓存 ---
Harmony/**/.appanalyzer/

# --- Harmony 构建输出 ---
Harmony/**/build/
Harmony/**/libs/

# --- Node.js ---
Harmony/**/node_modules/

