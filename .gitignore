STM32/**/Listings/
STM32/**/RTE/

# --- STM32CubeIDE ---
STM32/**/Debug/
STM32/**/Release/
STM32/**/.settings/
STM32/**/RemoteSystemsTempFiles/

# --- STM32CubeMX ---
STM32/**/*.mxproject
STM32/**/*.backup

# --- IAR Embedded Workbench ---
