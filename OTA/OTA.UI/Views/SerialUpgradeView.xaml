<UserControl x:Class="OTA.UI.Views.SerialUpgradeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="116" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="4,24,0,20" Background="#F7F7FA" SnapsToDevicePixels="True" RenderOptions.ClearTypeHint="Enabled">
            <StackPanel VerticalAlignment="Center"
                        TextOptions.TextFormattingMode="Display"
                        TextOptions.TextRenderingMode="ClearType"
                        TextOptions.TextHintingMode="Fixed">
                <TextBlock Style="{StaticResource H1TextStyle}" Text="{Binding ModeTitle}" />
                <TextBlock Style="{StaticResource HintTextStyle}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="Normal"
                           Text="{Binding ModeDescription}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2TextStyle}" Text="连接设置" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="串口号" />
                            <ComboBox x:Name="PortComboBox"
                                      IsEditable="False"
                                      IsReadOnly="True"
                                      IsTextSearchEnabled="False"
                                      IsEnabled="{Binding CanEditInputs}"
                                      ItemsSource="{Binding PortOptions}"
                                      SelectedItem="{Binding SelectedPort, Mode=TwoWay}"
                                      TextSearch.TextPath="PortName"
                                      SelectionChanged="PortComboBox_OnSelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock FontWeight="Medium" Text="{Binding PortName}" />
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="{Binding DisplayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDisplayDetail}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="波特率" />
                            <ComboBox IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      IsEnabled="{Binding CanEditInputs}"
                                      StaysOpenOnEdit="True"
                                      Text="{Binding BaudRateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="9600" />
                                <ComboBoxItem Content="19200" />
                                <ComboBoxItem Content="38400" />
                                <ComboBoxItem Content="57600" />
                                <ComboBoxItem Content="115200" />
                                <ComboBoxItem Content="230400" />
                                <ComboBoxItem Content="460800" />
                                <ComboBoxItem Content="921600" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="超时(秒)" />
                        <ComboBox Width="100"
                                  HorizontalAlignment="Left"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  IsEnabled="{Binding CanEditInputs}"
                                  StaysOpenOnEdit="True"
                                  Text="{Binding TimeoutText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Content="1" />
                            <ComboBoxItem Content="2" />
                            <ComboBoxItem Content="3" />
                            <ComboBoxItem Content="5" />
                            <ComboBoxItem Content="8" />
                            <ComboBoxItem Content="10" />
                            <ComboBoxItem Content="15" />
                            <ComboBoxItem Content="20" />
                        </ComboBox>
                        <TextBlock Style="{StaticResource HintTextStyle}" Margin="0,8,0,0" Text="{Binding ModeHint}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource H2TextStyle}" Text="固件与执行" />

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="当前槽位" />
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryHoverBrush}"
                                           Text="{Binding RunningSlotText}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="推荐镜像" />
                                <TextBlock Style="{StaticResource HintTextStyle}" Text="{Binding RecommendedImageText}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="{Binding PathLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Margin="0,0,12,0"
                                         IsEnabled="{Binding CanEditInputs}"
                                         Text="{Binding ScriptPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        MinWidth="96"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="BrowseScriptButton_OnClick"
                                        IsEnabled="{Binding CanBrowse}"
                                        Content="选择目录" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding ImageHintText}" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="1"
                                Background="#FEF3C7"
                                BorderBrush="#F59E0B"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,4"
                                Margin="0,0,16,0"
                                VerticalAlignment="Center">
                            <TextBlock FontWeight="Medium" Foreground="#D97706" Text="{Binding StatusText}" VerticalAlignment="Center" />
                        </Border>
                        <Button Grid.Column="2"
                                MinWidth="240"
                                Command="{Binding StartUpgradeCommand}"
                                Content="{Binding StartButtonText}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Margin="0" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource H2TextStyle}" Text="运行日志" Margin="0,0,0,12" />

                <TextBox Grid.Row="1"
                         x:Name="LogTextBox"
                         Style="{StaticResource LogTextBoxStyle}"
                         FontFamily="Consolas"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         Loaded="LogTextBox_OnLoaded"
                         PreviewMouseWheel="LogTextBox_OnPreviewMouseWheel"
                         Text="{Binding LogText, Mode=OneWay}"
                         TextChanged="LogTextBox_OnTextChanged"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
