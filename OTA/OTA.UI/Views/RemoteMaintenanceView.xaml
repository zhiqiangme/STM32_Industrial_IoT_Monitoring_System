<UserControl x:Class="OTA.UI.Views.RemoteMaintenanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="116" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="4,24,0,20"
                Background="#F7F7FA"
                SnapsToDevicePixels="True"
                RenderOptions.ClearTypeHint="Enabled">
            <StackPanel VerticalAlignment="Center"
                        TextOptions.TextFormattingMode="Display"
                        TextOptions.TextRenderingMode="ClearType"
                        TextOptions.TextHintingMode="Fixed">
                <TextBlock Style="{StaticResource H1TextStyle}" Text="{Binding ModeTitle}" />
                <TextBlock Style="{StaticResource HintTextStyle}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="Normal"
                           Text="{Binding ModeDescription}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource H2TextStyle}" Text="输入参数" Margin="0,0,0,0" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button MinWidth="144"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ImportClipboardButton_OnClick"
                                    Content="从剪贴板导入" />
                            <Button MinWidth="96"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="RecycleBinButton_OnClick"
                                    Content="回收站" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <TextBox x:Name="FrameImportTextBox"
                                     Height="42"
                                     Padding="12,0,104,0"
                                     FontFamily="Consolas"
                                     FontSize="18"
                                     VerticalContentAlignment="Center"
                                     ToolTip="粘贴完整原始帧后按 Enter 导入，也可右键直接从剪贴板导入"
                                     Text="{Binding FrameImportText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="FrameImportTextBox_OnKeyDown"
                                     PreviewMouseRightButtonUp="FrameImportTextBox_OnPreviewMouseRightButtonUp" />
                            <TextBlock Margin="0,0,12,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="{Binding FrameImportStatusText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#0F766E" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasFrameImportStatus}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsFrameImportWarning}" Value="True">
                                                <Setter Property="Foreground" Value="IndianRed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <UniformGrid Grid.Row="2"
                                     Columns="2"
                                     Rows="2">
                            <StackPanel Margin="0,0,12,16">
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="从站地址" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Height="42"
                                            Background="#E2E8F0"
                                            Foreground="#334155"
                                            FontFamily="Consolas"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            Command="{Binding ToggleFieldBaseCommand}"
                                            CommandParameter="SlaveAddressText"
                                            Content="{Binding SlaveAddressBaseText}" />
                                    <TextBox Grid.Column="1"
                                             Height="42"
                                             FontSize="18"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding SlaveAddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <TextBlock Style="{StaticResource HintTextStyle}" Margin="0,6,0,0" Text="1 字节，可切换 HEX / DEC 输入" />
                            </StackPanel>

                            <StackPanel Margin="12,0,0,16">
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="功能码" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Height="42"
                                            Background="#E2E8F0"
                                            Foreground="#334155"
                                            FontFamily="Consolas"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            Command="{Binding ToggleFieldBaseCommand}"
                                            CommandParameter="FunctionCodeText"
                                            Content="{Binding FunctionCodeBaseText}" />
                                    <TextBox Grid.Column="1"
                                             Height="42"
                                             FontSize="18"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding FunctionCodeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <TextBlock Style="{StaticResource HintTextStyle}" Margin="0,6,0,0" Text="1 字节，例如 03 / 06 / 10" />
                            </StackPanel>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="寄存器地址" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Height="42"
                                            Background="#E2E8F0"
                                            Foreground="#334155"
                                            FontFamily="Consolas"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            Command="{Binding ToggleFieldBaseCommand}"
                                            CommandParameter="RegisterAddressText"
                                            Content="{Binding RegisterAddressBaseText}" />
                                    <TextBox Grid.Column="1"
                                             Height="42"
                                             FontSize="18"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding RegisterAddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <TextBlock Style="{StaticResource HintTextStyle}" Margin="0,6,0,0" Text="2 字节，高字节在前" />
                            </StackPanel>

                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="数据" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Height="42"
                                            Background="#E2E8F0"
                                            Foreground="#334155"
                                            FontFamily="Consolas"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            BorderThickness="0"
                                            Command="{Binding ToggleFieldBaseCommand}"
                                            CommandParameter="DataText"
                                            Content="{Binding DataBaseText}" />
                                    <TextBox Grid.Column="1"
                                             Height="42"
                                             FontSize="18"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding DataText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <TextBlock Style="{StaticResource HintTextStyle}" Margin="0,6,0,0" Text="2 字节，按寄存器写入值" />
                            </StackPanel>
                        </UniformGrid>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <Button Width="160"
                                Command="{Binding GenerateCommand}"
                                Content="生成并复制" />
                        <Button Width="120"
                                Margin="12,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding FillExampleCommand}"
                                Content="填入示例" />
                        <Button Width="120"
                                Margin="12,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ImportFrameCommand}"
                                Content="导入当前帧" />
                        <TextBlock Margin="16,10,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   Text="示例：10 / 06 / 0030 / 42330" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource H2TextStyle}" Text="生成结果" Margin="0,0,0,0" />

                        <Border Grid.Column="1"
                                Padding="16,10"
                                CornerRadius="12"
                                Background="#1E293B">
                            <StackPanel>
                                <TextBlock FontSize="12"
                                           Foreground="#94A3B8"
                                           Text="当前状态" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#F8FAFC"
                                           Text="{Binding HeaderStatusText}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="16"
                            CornerRadius="16"
                            Background="#0F172A">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       Foreground="#93C5FD"
                                       Text="原始帧" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       FontSize="22"
                                       TextWrapping="Wrap"
                                       Text="{Binding RawFrameText}" />
                        </StackPanel>
                    </Border>

                    <UniformGrid Grid.Row="4" Columns="2">
                        <Border Margin="0,0,8,0"
                                Padding="14"
                                CornerRadius="14"
                                Background="White">
                            <StackPanel>
                                <TextBlock Foreground="#64748B" Text="CRC16" />
                                <TextBlock Margin="0,6,0,0"
                                           FontFamily="Consolas"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           Text="{Binding CrcText}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="8,0,0,0"
                                Padding="14"
                                CornerRadius="14"
                                Background="White">
                            <StackPanel>
                                <TextBlock Foreground="#64748B" Text="复制状态" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#0F766E"
                                           Text="{Binding CopyStatusText}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Row="6"
                            Padding="16"
                            CornerRadius="16"
                            Background="White">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#0F172A"
                                       Text="下一步" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#334155"
                                       TextWrapping="Wrap"
                                       Text="{Binding NextStepText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
