<Window x:Class="Project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="STM32 OTA 升级工具"
        Height="760"
        Width="1040"
        MinHeight="700"
        MinWidth="920"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF5F7FA" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20"
                CornerRadius="14"
                Background="White"
                BorderBrush="#FFD9E1EA"
                BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="ModeTitleTextBlock"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#FF16324F"
                           Text="STM32 本地 OTA 升级" />

                <TextBlock x:Name="ModeDescriptionTextBlock"
                           Margin="0,8,0,20"
                           Foreground="#FF4F6478"
                           TextWrapping="Wrap"
                           Text="流程：发送解锁 HEX -> 等待 500ms -> 发送进入 Bootloader HEX -> 调用 PowerShell 执行 Python 刷机脚本。" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center" Text="升级方式" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="LocalModeButton"
                                Width="132"
                                Height="34"
                                Margin="0,0,8,0"
                                Click="LocalModeButton_OnClick"
                                Content="本地升级" />
                        <Button x:Name="RemoteModeButton"
                                Width="132"
                                Height="34"
                                Click="RemoteModeButton_OnClick"
                                Content="在线升级" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="LocalConfigGrid" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="串口号" />
                    <DockPanel Grid.Column="1" Margin="0,0,16,0">
                        <Button x:Name="RefreshPortsButton"
                                Width="88"
                                Margin="8,0,0,0"
                                Padding="10,6"
                                Click="RefreshPortsButton_OnClick"
                                Content="刷新串口"
                                DockPanel.Dock="Right" />
                        <ComboBox x:Name="PortComboBox"
                                  Height="38"
                                  IsEditable="True"
                                  TextSearch.TextPath="PortName"
                                  SelectionChanged="PortComboBox_OnSelectionChanged"
                                  VerticalContentAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding PortName}" />
                                        <TextBlock FontSize="12"
                                                   Foreground="#FF5F7286"
                                                   Text="{Binding DisplayName}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </DockPanel>

                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="波特率" />
                    <TextBox x:Name="BaudRateTextBox"
                             Grid.Column="3"
                             Height="38"
                             VerticalContentAlignment="Center"
                             Text="115200" />
                </Grid>

                <Grid x:Name="RemoteConfigGrid" Margin="0,0,0,12" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="远程主机" />
                    <TextBox x:Name="RemoteHostTextBox"
                             Grid.Column="1"
                             Height="38"
                             Margin="0,0,16,0"
                             VerticalContentAlignment="Center"
                             Text="0.0.0.0" />

                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="TCP 端口" />
                    <TextBox x:Name="RemotePortTextBox"
                             Grid.Column="3"
                             Height="38"
                             VerticalContentAlignment="Center"
                             Text="8899" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="超时(秒)" />
                    <TextBox x:Name="TimeoutTextBox"
                             Grid.Column="1"
                             Height="38"
                             VerticalContentAlignment="Center"
                             Text="5" />

                    <TextBlock x:Name="ModeHintTextBlock"
                               Grid.Column="3"
                               VerticalAlignment="Center"
                               Foreground="#FF4F6478"
                               Text="默认优先选择 USB-SERIAL CH340 串口。" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="脚本路径" />
                    <DockPanel Grid.Column="1">
                        <Button x:Name="BrowseScriptButton"
                                Width="96"
                                Margin="8,0,0,0"
                                Padding="10,6"
                                Click="BrowseScriptButton_OnClick"
                                Content="选择脚本"
                                DockPanel.Dock="Right" />
                        <TextBox x:Name="ScriptPathTextBox"
                                 Height="38"
                                 VerticalContentAlignment="Center"
                                 Text="D:\Project\STM32_Mill\stm32_local_upgrade.py" />
                    </DockPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="BootloaderPanel"
                Grid.Row="1"
                Margin="0,16,0,16"
                Padding="20"
                CornerRadius="14"
                Background="White"
                BorderBrush="#FFD9E1EA"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FF16324F"
                           Text="Bootloader 指令" />

                <UniformGrid Grid.Row="1"
                             Margin="0,14,0,16"
                             Columns="2">
                    <Border Margin="0,0,8,0"
                            Padding="12"
                            CornerRadius="10"
                            Background="#FFF7FAFC"
                            BorderBrush="#FFE0E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="HEX 解锁代码" />
                            <TextBlock Margin="0,6,0,0"
                                       FontFamily="Consolas"
                                       Text="0a060030a55a73d5" />
                        </StackPanel>
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="12"
                            CornerRadius="10"
                            Background="#FFF7FAFC"
                            BorderBrush="#FFE0E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="HEX 进入 Bootloader 代码" />
                            <TextBlock Margin="0,6,0,0"
                                       FontFamily="Consolas"
                                       Text="0a0600310005197d" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal">
                    <Button x:Name="StartUpgradeButton"
                            Width="220"
                            Height="42"
                            Padding="16,10"
                            Click="StartUpgradeButton_OnClick"
                            Content="进入 Bootloader 并刷机" />
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#FF4F6478"
                               Text="待机" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="20"
                CornerRadius="14"
                Background="White"
                BorderBrush="#FFD9E1EA"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FF16324F"
                           Text="运行日志" />

                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Margin="0,14,0,0"
                         FontFamily="Consolas"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
