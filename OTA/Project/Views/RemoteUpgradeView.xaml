<!-- RemoteUpgradeView.xaml：放远程升级页面布局、状态展示、操作按钮和日志区域。 -->
<UserControl x:Class="Project.RemoteUpgradeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1126">
    <Grid Background="#F7F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="116" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="4,24,0,20" Background="#F7F7FA">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Style="{StaticResource H1TextStyle}" Text="STM32 远程 OTA 升级" />
                <TextBlock Style="{StaticResource HintTextStyle}" Text="流程：读取远程清单 -> 选择推荐固件 -> 下载并校验 -> 复用本地串口升级流程完成刷写。" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2TextStyle}" Text="远程源配置" />

                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="远程清单地址" />
                    <TextBox Text="{Binding ManifestUrl, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource HintTextStyle}" Margin="0,8,0,16"
                               Text="请输入完整的 manifest.json 地址。远程升级会根据设备当前运行槽位自动推荐另一槽固件。" />

                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="固件缓存目录" />
                    <TextBox Text="{Binding DownloadDirectory, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource HintTextStyle}" Margin="0,8,0,0"
                               Text="下载的远程固件会先缓存在本地目录，再复用本地升级流程进行刷写。" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2TextStyle}" Text="设备上下文" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="当前串口参数" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding DevicePortText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="当前运行槽位" />
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding RunningSlotText}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Style="{StaticResource HintTextStyle}"
                               Text="本页沿用本地页当前已选的串口、波特率和超时参数；如果需要修改连接参数，请先切回本地升级页调整。" />

                    <Button Margin="0,16,0,0"
                            Width="120"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="RefreshDeviceButton_OnClick"
                            Content="刷新设备信息"
                            IsEnabled="{Binding CanRefreshDevice}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource H2TextStyle}" Text="远程版本与执行" />

                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="最新远程版本" />
                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryHoverBrush}" Text="{Binding LatestVersionText}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="候选固件包" />
                            <ComboBox ItemsSource="{Binding AvailablePackages}"
                                      SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayText" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="发布说明" />
                        <TextBox MinHeight="88"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ReleaseNotes, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="3">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ProgressBar Height="10"
                                         Minimum="0"
                                         Maximum="100"
                                         VerticalAlignment="Center"
                                         Value="{Binding ProgressPercent}" />

                            <Border Grid.Column="1" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1"
                                    CornerRadius="6" Padding="12,4" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontWeight="Medium" Foreground="#D97706" Text="{Binding StatusText}" />
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="120"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="CheckUpdatesButton_OnClick"
                                    Content="检查更新"
                                    IsEnabled="{Binding CanCheckUpdates}" />
                            <Button Width="140"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="DownloadPackageButton_OnClick"
                                    Content="下载固件"
                                    IsEnabled="{Binding CanDownloadSelectedPackage}" />
                            <Button Width="180"
                                    Margin="12,0,0,0"
                                    Click="StartUpgradeButton_OnClick"
                                    Content="下载并升级"
                                    IsEnabled="{Binding CanStartUpgrade}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource H2TextStyle}" Text="远程升级日志" Margin="0,0,0,12" />

                    <TextBox Grid.Row="1"
                             Style="{StaticResource LogTextBoxStyle}"
                             FontFamily="Consolas"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Text="{Binding LogText, Mode=OneWay}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
