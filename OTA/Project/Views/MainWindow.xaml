<Window x:Class="Project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:Project"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="STM32 OTA 升级工具"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Icon="/Assets/OTA.png"
        Height="800"
        Width="1166"
        MinHeight="750"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Microsoft YaHei"
        Background="#F7F7FA"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled">
    <!-- MainWindow.xaml：放 OTA 主界面的布局、样式、控件和事件绑定。 -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="10"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Background="#F7F7FA" ClipToBounds="True">
    <Border Background="#F7F7FA" BorderBrush="Transparent" BorderThickness="0" CornerRadius="10" SnapsToDevicePixels="True" RenderOptions.ClearTypeHint="Enabled" ClipToBounds="True">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" /> <!-- 自定义标题栏 -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 带标签页的自定义标题栏 -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource TitleBarBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0"
                    ClipToBounds="True"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧模式标签 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Button x:Name="LocalModeButton" Content="本地升级" Padding="26,6" MinWidth="172" Margin="0,0,6,0" Height="40" FontSize="18"
                                Click="LocalModeButton_OnClick" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource TitleBarBrush}" />
                                    <Setter Property="Foreground" Value="#4B5563" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="9"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FDFDFE" />
                                                        <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="RemoteModeButton" Content="远程升级" Padding="26,6" MinWidth="172" Margin="0,0,6,0" Height="40" FontSize="18"
                                Click="RemoteModeButton_OnClick" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource TitleBarBrush}" />
                                    <Setter Property="Foreground" Value="#4B5563" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="9"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FDFDFE" />
                                                        <Setter TargetName="border" Property="BorderBrush" Value="Transparent" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- 关闭按钮 -->
                    <Button Grid.Column="1" Click="CloseButton_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Width="46" Height="44">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="0"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True">
                                                <TextBlock x:Name="closeIcon" Text="✕" Foreground="#475569" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#DC2626" />
                                                    <Setter TargetName="closeIcon" Property="Foreground" Value="White" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 本地升级页面 -->
            <Grid x:Name="LocalContentGrid" Grid.Row="1" Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="116" /> <!-- 页头说明 -->
            <RowDefinition Height="Auto" /> <!-- 顶部信息卡片 -->
            <RowDefinition Height="*" />    <!-- 运行日志 -->
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Margin="4,24,0,20" Background="#F7F7FA" SnapsToDevicePixels="True" RenderOptions.ClearTypeHint="Enabled">
        <StackPanel VerticalAlignment="Center" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType" TextOptions.TextHintingMode="Fixed">
            <TextBlock x:Name="ModeTitleTextBlock" Style="{StaticResource H1TextStyle}" Text="STM32 本地 OTA 升级" />
            <TextBlock x:Name="ModeDescriptionTextBlock" Style="{StaticResource HintTextStyle}" Text="流程：发送解锁 HEX -> 等待 500ms -> 发送进入 Bootloader HEX -> 由 C# 内置 YMODEM 发送 STM32 程序。" />
        </StackPanel>
        </Border>

        <!-- 顶部两张卡片：连接设置 / 固件与执行 -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="20" /> <!-- 中间间距 -->
                <ColumnDefinition Width="1.2*" /> <!-- 右侧卡片略宽，方便容纳较长路径 -->
            </Grid.ColumnDefinitions>

            <!-- 左卡片：连接设置 -->
            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2TextStyle}" Text="连接设置" />

                    <!-- 串口与波特率 -->
                    <Grid x:Name="LocalConfigGrid" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="串口号" />
                            <ComboBox x:Name="PortComboBox" IsEditable="False" IsReadOnly="True" IsTextSearchEnabled="False" TextSearch.TextPath="PortName" SelectionChanged="PortComboBox_OnSelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock FontWeight="Medium" Text="{Binding PortName}" />
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="{Binding DisplayName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding HasDisplayDetail}" Value="True" />
                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem}, Path=IsVisible}" Value="True" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource LabelTextStyle}" Text="波特率" />
                            <ComboBox x:Name="BaudRateComboBox" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" Text="115200">
                                <ComboBoxItem Content="9600" />
                                <ComboBoxItem Content="19200" />
                                <ComboBoxItem Content="38400" />
                                <ComboBoxItem Content="57600" />
                                <ComboBoxItem Content="115200" />
                                <ComboBoxItem Content="230400" />
                                <ComboBoxItem Content="460800" />
                                <ComboBoxItem Content="921600" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- 超时与提示 -->
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelTextStyle}" Text="超时(秒)" />
                        <ComboBox x:Name="TimeoutComboBox" Width="100" HorizontalAlignment="Left" IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" Text="5">
                            <ComboBoxItem Content="1" />
                            <ComboBoxItem Content="2" />
                            <ComboBoxItem Content="3" />
                            <ComboBoxItem Content="5" />
                            <ComboBoxItem Content="8" />
                            <ComboBoxItem Content="10" />
                            <ComboBoxItem Content="15" />
                            <ComboBoxItem Content="20" />
                        </ComboBox>
                        <TextBlock x:Name="ModeHintTextBlock" Style="{StaticResource HintTextStyle}" Margin="0,8,0,0" Text="空闲时自动刷新串口列表，并优先选择 USB-SERIAL CH340 串口。" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 右卡片：固件与执行 -->
            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <!-- 使用内部网格把操作区压到卡片底部 -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource H2TextStyle}" Text="固件与执行" />

                        <!-- 设备状态行 -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="当前槽位" />
                                <TextBlock x:Name="RunningSlotTextBlock" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryHoverBrush}" Text="未读取" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource LabelTextStyle}" Text="推荐镜像" />
                                <TextBlock x:Name="RecommendedImageTextBlock" Style="{StaticResource HintTextStyle}" Text="请连接设备后等待自动识别..." />
                            </StackPanel>
                        </Grid>

                        <!-- 镜像路径 -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock x:Name="PathLabelTextBlock" Style="{StaticResource LabelTextStyle}" Text="STM32 固件程序路径" />
                            <DockPanel>
                                <Button x:Name="BrowseScriptButton" Width="90" Margin="12,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="BrowseScriptButton_OnClick" Content="选择文件" DockPanel.Dock="Right" />
                                <TextBox x:Name="ScriptPathTextBox" TextChanged="ScriptPathTextBox_OnTextChanged" Text="D:\Project\STM32_Mill\STM32\MDK-ARM\Objects\App_A.bin" />
                            </DockPanel>
                            <TextBlock x:Name="ImageHintTextBlock" Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="镜像槽位：未检查。" />
                        </StackPanel>
                    </StackPanel>

                    <!-- 底部操作区 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="6" Padding="12,4" Margin="0,0,16,0" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusTextBlock" FontWeight="Medium" Foreground="#D97706" Text="待机" VerticalAlignment="Center" />
                        </Border>
                        <Button x:Name="StartUpgradeButton" Width="180" Click="StartUpgradeButton_OnClick" Content="进入 Bootloader 并刷机" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 运行日志面板 -->
        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Margin="0" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Style="{StaticResource H2TextStyle}" Text="运行日志" Margin="0,0,0,12" />

                <!-- 类开发工具风格的日志窗口 -->
                <TextBox x:Name="LogTextBox"
                         Grid.Row="1"
                         Style="{StaticResource LogTextBoxStyle}"
                         FontFamily="Consolas"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         />
            </Grid>
        </Border>
        </Grid>

            <!-- 远程升级页面 -->
            <Grid x:Name="RemoteContentGrid" Grid.Row="1" Margin="20,0,20,20" Visibility="Collapsed">
                <local:RemoteUpgradeView x:Name="RemoteUpgradeViewControl" />
            </Grid>
        </Grid>
    </Border>
    </Grid>
</Window>
