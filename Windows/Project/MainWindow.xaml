<Window x:Class="Project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project"
        mc:Ignorable="d"
        Title="Modbus上位机" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Foreground="White"
        Background="Transparent"
        Icon="pack://application:,,,/Resources/v1.0.0/STM32_Mill_v1.0.0.ico">

    <Window.Resources>
        <!-- 颜色资源定义 -->
        <Color x:Key="CardBackgroundColor">#202020</Color>
        <Color x:Key="AccentColor">#4CAF50</Color>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" Opacity="0.6"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="DividerBrush" Color="#404040"/>

        <!-- 样式定义 -->
        <!-- 卡片样式: 圆角、半透明背景、阴影效果 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 分组框样式 -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 转换器资源 -->
        <!-- 用于将布尔值 (true/false) 转换为颜色画刷 (绿色/灰色) -->
        <local:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 第一行: 顶部控制栏 -->
            <RowDefinition Height="Auto"/> <!-- 第二行: 主数据仪表盘 -->
            <RowDefinition Height="*"/>    <!-- 第三行: 详细日志区域 (自适应高度) -->
            <RowDefinition Height="Auto"/> <!-- 第四行: 底部状态栏 -->
        </Grid.RowDefinitions>

        <!-- ============== 顶部控制栏 ============== -->
        <Border Grid.Row="0" 
                Margin="0,0,0,16" 
                Padding="12" 
                Background="#151515" 
                CornerRadius="8" 
                Opacity="0.8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- 串口选择 -->
                <TextBlock Text="COM:" 
                           VerticalAlignment="Center" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="PortComboBox" 
                          Width="100" 
                          Height="25"
                          VerticalContentAlignment="Center"
                          Margin="0,0,16,0"
                          PreviewMouseDown="PortComboBox_PreviewMouseDown">
                    <!-- 1. 选择框显示：仅显示端口名 -->

                    
                    <!-- 2. 下拉列表显示：显示完整描述 -->
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding PortName}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayDescription}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <!-- x:Name="PortComboBox" 用于在代码中访问此控件 -->
                
                <!-- 刷新串口按钮 -->
                <Button Content="刷新" 
                        Click="RefreshPorts_Click" 
                        Height="25"
                        Margin="0,0,16,0" 
                        Padding="8,0"/>

                <!-- 波特率选择 -->
                <TextBlock Text="波特率:" 
                           VerticalAlignment="Center" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="BaudComboBox" 
                          Width="100" 
                          Height="25"
                          VerticalContentAlignment="Center"
                          Margin="0,0,16,0" 
                          IsEditable="True">
                    <!-- IsEditable="True" 允许用户手动输入波特率 -->
                    <!-- 波特率从小到大排序 -->
                    <ComboBoxItem Content="1200"/>
                    <ComboBoxItem Content="2400"/>
                    <ComboBoxItem Content="4800"/>
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="19200"/>
                    <ComboBoxItem Content="38400"/>
                    <ComboBoxItem Content="57600"/>
                    <ComboBoxItem Content="115200" IsSelected="True"/>
                    <ComboBoxItem Content="230400"/>
                    <ComboBoxItem Content="460800"/>
                    <ComboBoxItem Content="921600"/>
                </ComboBox>

                <!-- 连接/断开按钮 -->
                <Button x:Name="ConnectButton" 
                        Content="连接设备" 
                        Click="ConnectButton_Click" 
                        Width="100" 
                        Height="25"
                        Background="#2196F3"
                        Foreground="White" 
                        FontWeight="Bold" 
                        Margin="0,0,16,0" 
                        Padding="8,0"/>
                <!-- 连接时背景变为红色 #FF5252，文字变为"断开" -->
                
                <!-- 自动轮询开关 -->
                <ToggleButton x:Name="TogglePollButton" 
                              Content="自动轮询" 
                              Click="TogglePoll_Click" 
                              Width="100" 
                              Height="25"
                              Margin="0,0,8,0" 
                              IsEnabled="False"/>

                <!-- 轮询间隔设置 -->
                <ComboBox x:Name="PollIntervalBox" 
                          Width="80" 
                          Height="25"
                          VerticalContentAlignment="Center"
                          HorizontalContentAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="0,0,4,0" 
                          Text="500" 
                          IsEditable="True">
                    <ComboBoxItem Content="100"/>
                    <ComboBoxItem Content="200"/>
                    <ComboBoxItem Content="500" IsSelected="True"/>
                    <ComboBoxItem Content="1000"/>
                    <ComboBoxItem Content="2000"/>
                    <ComboBoxItem Content="5000"/>
                </ComboBox>
                <TextBlock Text="ms" 
                           VerticalAlignment="Center" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,0,0,0"/>
                <!-- 轮询间隔单位：毫秒，连接后禁止修改 -->
            </StackPanel>
        </Border>

        <!-- 中部: 主要数据卡片 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 卡片 1: 称重显示 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="称重 (Weight)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <TextBlock x:Name="MainWeightText" Text="0.00" FontSize="48" FontWeight="Bold" Foreground="#FF5252"/>
                        <TextBlock x:Name="MainWeightUnit" Text="g" FontSize="20" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                    </StackPanel>
                    <TextBlock Text="通道: CH3" HorizontalAlignment="Right" FontSize="10" Foreground="#666" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- 卡片 2: 温度显示 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="温度 (Temp)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <TextBlock x:Name="MainTempText" Text="0.0" FontSize="48" FontWeight="Bold" Foreground="#448AFF"/>
                        <TextBlock Text="°C" FontSize="20" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                    </StackPanel>
                    <TextBlock Text="通道: CH4" HorizontalAlignment="Right" FontSize="10" Foreground="#666" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- 卡片 3: 流量显示 -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="瞬时流量 (Flow Rate)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <TextBlock x:Name="MainFlowText" Text="0.00" FontSize="48" FontWeight="Bold" Foreground="#69F0AE"/>
                        <TextBlock Text="L/min" FontSize="20" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                    </StackPanel>
                    <TextBlock x:Name="TotalFlowText" Text="累计: 0.000 m³" HorizontalAlignment="Center" FontSize="14" Foreground="#CCC" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 下部: 详细信息区域 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧: 系统状态 & 继电器矩阵 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="8,0,8,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="系统状态" Foreground="{StaticResource TextSecondaryBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 继电器输出 (DO) 指示灯 -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="继电器输出 (DO)" FontSize="16" FontWeight="Bold" Foreground="#69F0AE" Margin="0,0,0,12"/>
                            <UniformGrid Rows="2" Columns="8" HorizontalAlignment="Left">
                                <Ellipse x:Name="DO0" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO1" Tag="1" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO1" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO2" Tag="2" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO2" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO3" Tag="3" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO3" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO4" Tag="4" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO4" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO5" Tag="5" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO5" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO6" Tag="6" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO6" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO7" Tag="7" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO7" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO8" Tag="8" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO8" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO9" Tag="9" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO9" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO10" Tag="10" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO10" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO11" Tag="11" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO11" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO12" Tag="12" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO12" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO13" Tag="13" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO13" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO14" Tag="14" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO14" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO15" Tag="15" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                                <Ellipse x:Name="DO15" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DO16" Tag="16" Cursor="Hand" MouseLeftButtonDown="RelayOutput_Click"/>
                            </UniformGrid>
                            <TextBlock x:Name="RelayDoHex" Text="DO: 0x0000" FontSize="14" Foreground="#888" Margin="4,8,0,0"/>
                            <TextBlock x:Name="RelayBitsHex" Text="状态位图(0x0014): 0x0000" FontSize="12" Foreground="#777" Margin="4,4,0,0"/>
                            <Button Content="全关"
                                    Click="RelayAllOff_Click"
                                    Height="25"
                                    Margin="4,8,0,0"
                                    Padding="10,0"
                                    Width="80"/>
                        </StackPanel>

                        <!-- 继电器输入 (DI) 指示灯 -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="继电器输入 (DI)" FontSize="16" FontWeight="Bold" Foreground="#448AFF" Margin="0,0,0,12"/>
                            <UniformGrid Rows="2" Columns="8" HorizontalAlignment="Left">
                                <Ellipse x:Name="DI0" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI1" Tag="1" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI1" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI2" Tag="2" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI2" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI3" Tag="3" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI3" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI4" Tag="4" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI4" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI5" Tag="5" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI5" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI6" Tag="6" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI6" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI7" Tag="7" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI7" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI8" Tag="8" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI8" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI9" Tag="9" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI9" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI10" Tag="10" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI10" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI11" Tag="11" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI11" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI12" Tag="12" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI12" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI13" Tag="13" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI13" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI14" Tag="14" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI14" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI15" Tag="15" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                                <Ellipse x:Name="DI15" Width="20" Height="20" Margin="4" Fill="Gray" ToolTip="DI16" Tag="16" Cursor="Hand" MouseLeftButtonDown="RelayInput_MouseDown" MouseLeftButtonUp="RelayInput_MouseUp"/>
                            </UniformGrid>
                            <TextBlock x:Name="RelayDiHex" Text="DI: 0x0000" FontSize="14" Foreground="#888" Margin="4,8,0,0"/>
                            <Button Content="清除标记"
                                    Click="ClearInputMarks_Click"
                                    Height="25"
                                    Margin="4,8,0,0"
                                    Padding="10,0"
                                    Width="80"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- 右侧: 原始数据滚动日志 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,8,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="详细数据 (通道 1-2, 状态位)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="DetailLogText" Foreground="#DDD" FontFamily="Consolas" FontSize="14" TextWrapping="Wrap" LineHeight="22"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部: 状态栏 -->
        <Border Grid.Row="3" Background="#111" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="就绪" Foreground="#888"/>
                <TextBlock x:Name="LastUpdateText" Grid.Column="1" Text="上次更新: -" Foreground="#666" Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
