<Window x:Class="OTA.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:OTA.UI.Views"
        mc:Ignorable="d"
        Title="STM32 OTA 升级工具"
        Icon="Assets/OTA.png"
        Height="800"
        Width="1166"
        MinHeight="750"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Microsoft YaHei"
        Background="#F7F7FA"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled">
    <TabControl Style="{StaticResource ShellTabControlStyle}"
                ItemContainerStyle="{StaticResource ShellTabItemStyle}"
                SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
        <TabItem Header="本地升级">
            <views:LocalUpgradeView DataContext="{Binding LocalVM}" />
        </TabItem>
        <TabItem Header="远程升级">
            <views:RemoteUpgradeView DataContext="{Binding RemoteVM}" />
        </TabItem>
    </TabControl>
</Window>
